# ============================
# ENVIRONMENT
# ============================
NODE_ENV=development
PORT=3001

# ============================
# DATABASE
# ============================
DATABASE_URL="postgresql://user:password@localhost:5432/skulafrica?schema=public"

# ============================
# JWT SECRETS (MUST BE 64+ CHARS, RANDOM, SECURE)
# ============================
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=your-super-secret-jwt-access-key-minimum-64-characters-long-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-jwt-refresh-key-minimum-64-characters-long-change-this-in-production

# ============================
# CORS
# ============================
# Comma-separated allowed origins
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ============================
# EMAIL / MAILER (Nodemailer or @nestjs-modules/mailer)
# ============================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-specific-password
MAIL_FROM=noreply@zibhoz.com

# ============================
# EMAIL RETRY & RATE LIMITING
# ============================
EMAIL_MAX_RETRIES=5
EMAIL_RETRY_DELAYS=60000,300000,900000,3600000,14400000
EMAIL_RATE_LIMIT_MAX=100
EMAIL_RATE_LIMIT_WINDOW=3600000

# ============================
# APP URL (used for email links)
# ============================
APP_URL=http://localhost:3000

# ============================
# OPTIONAL: Mailer service URL (if using external email service)
# ============================
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=
# SENDGRID_API_KEY=